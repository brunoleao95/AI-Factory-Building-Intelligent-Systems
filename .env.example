# =============================================================
# LLM Local (Ollama) - usado pelo backend (api.py / app.py)
# =============================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
# Modelo dedicado a CrewAI (etapa 2). Use modelo 7B+ para function calling
# confiavel. Ex: gpt-oss:20b-cloud (Ollama Cloud free tier), llama3.1:8b (local).
# Se nao definir, cai no OLLAMA_MODEL acima.
OLLAMA_CREW_MODEL=gpt-oss:20b-cloud

# Flowise (opcional)
FLOWISE_URL=http://localhost:3000

# Cloud APIs (preencher se necessario)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================
# Langfuse (etapa 2 - observabilidade). Opcional: sem chaves o
# decorator @observe vira no-op e o app roda normalmente.
# Crie conta gratuita em https://cloud.langfuse.com -> projeto -> API Keys
# =============================================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================
# Etapa 3 - Deploy hibrido (backend FastAPI local + frontend Streamlit Cloud)
# =============================================================
# Segredo compartilhado entre o backend (api.py) e o frontend (app_cloud.py).
# O frontend envia este valor no header X-API-Key; o backend valida.
# Gere um valor aleatorio (ex.: python -c "import secrets; print(secrets.token_urlsafe(32))").
API_KEY=

# URL publica do backend (ngrok com dominio estatico). O frontend no
# Streamlit Cloud le isto via st.secrets; localmente cai no default abaixo.
# Ex.: https://seu-nome.ngrok-free.app
BACKEND_URL=http://localhost:8000

# Dominio estatico do ngrok (free tier da 1 gratis), usado por
# scripts/start_public.ps1. Ex.: seu-nome.ngrok-free.app
NGROK_DOMAIN=

# =============================================================
# Etapa 3 - Guardrails (seguranca)
# =============================================================
# Liga/desliga toda a camada de guardrails. Default: ativo.
GUARDRAILS_ENABLED=true
# Usa o LLM local (llama3.2) como juiz para casos ambiguos de
# toxicidade/topicos quando os modelos HF nao tem certeza. Default: ativo.
GUARDRAILS_LLM_JUDGE=true
