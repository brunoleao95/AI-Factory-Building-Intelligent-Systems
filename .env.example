# LLM Local (Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
# Modelo dedicado a CrewAI (etapa 2). Use modelo 7B+ para function calling
# confiavel. Ex: gpt-oss:20b-cloud (Ollama Cloud free tier), llama3.1:8b (local).
# Se nao definir, cai no OLLAMA_MODEL acima.
OLLAMA_CREW_MODEL=gpt-oss:20b-cloud

# Flowise (opcional)
FLOWISE_URL=http://localhost:3000

# Cloud APIs (preencher se necessario)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Langfuse (etapa 2 - observabilidade)
# Crie conta gratuita em https://cloud.langfuse.com -> projeto -> API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
